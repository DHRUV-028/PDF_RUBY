<p style="color: green"><%= notice %></p>

<% content_for :title, "Infos" %>

<h1>Infos</h1>

<%=link_to "All Infos", infos_path(format: :pdf)%>
<div id="infos">
  <% @infos.each do |info| %>
    <%= render info %>
    <p>
      <%= link_to "Show this info", info %>
    </p>
  <% end %>
</div>

<%= link_to "New info", new_info_path %>
